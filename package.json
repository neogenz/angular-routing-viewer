{
  "name": "angular-routing-viewer",
  "version": "0.1.1",
  "description": "CLI that statically analyzes Angular project routing and generates an interactive visual graph.",
  "type": "module",
  "bin": {
    "ngrv": "dist/ngrv.js"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "angular",
    "routing",
    "routes",
    "graph",
    "visualization",
    "cli",
    "static-analysis"
  ],
  "homepage": "https://github.com/neogenz/angular-routing-viewer#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/neogenz/angular-routing-viewer.git"
  },
  "bugs": {
    "url": "https://github.com/neogenz/angular-routing-viewer/issues"
  },
  "author": "Maxime De Sogus <maxime.desogus@gmail.com>",
  "license": "MIT",
  "scripts": {
    "start": "bun bin/ngrv.ts",
    "build": "bun run scripts/build.ts",
    "typecheck": "bun tsc --noEmit",
    "test": "NO_COLOR=1 bun test",
    "prepublishOnly": "bun run scripts/build.ts"
  },
  "dependencies": {
    "@clack/prompts": "^1.6.0",
    "ts-morph": "^28.0.0"
  },
  "devDependencies": {
    "bun-types": "latest",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18.3.0",
    "bun": ">=1.0.0"
  }
}
